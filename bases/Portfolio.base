views:
  - type: table
    name: Table
    filters:
      and:
        - file.folder == "_portfolio"
    order:
      - file.name
      - title
      - published
      - date
      - updated
      - image
      - tags
    sort:
      - property: file.name
        direction: ASC
      - property: date
        direction: DESC
    columnSize:
      file.name: 231
      note.title: 247
